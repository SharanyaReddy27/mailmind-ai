# Used by src/services/api.js (the shared axios client all requests,
# including AI requests, now go through). Leave unset in local dev to
# use the "/api" -> http://localhost:5000 proxy configured in
# vite.config.js. Set to your API's absolute origin (e.g.
# https://api.example.com/api) for production builds.
VITE_API_URL=
